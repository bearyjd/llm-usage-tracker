# LLM Usage Tracker — Environment Variables
# Copy this file to .env and fill in your values

# --- API SPEND TRACKING ---
# Option A (preferred): LiteLLM proxy — covers all providers in one call.
# Set both to enable if you run a LiteLLM proxy.
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Option B (fallback): per-provider keys/sessions used when LiteLLM is not configured.

# OpenAI API key — enables spend/token tracking via api.openai.com/v1/dashboard/billing
OPENAI_API_KEY=

# Google AI Studio API key — enables model availability check via generativelanguage.googleapis.com
# NOTE: Cumulative spend requires GCP billing export (BigQuery). Not available via simple API.
GOOGLE_API_KEY=

# Groq API key — validates key and reports available models
# (cumulative spend requires llm-tracker auth groq --api)
GROQ_API_KEY=

# Override Groq daily token limit if you have a paid/Flex plan (default: free tier per-model limits)
# GROQ_DAILY_TOKEN_LIMIT=1000000

# NOTE: Claude API spend is tracked by scraping console.anthropic.com.
# Run: llm-tracker auth claude --api  (separate one-time setup)

# Database path (default: data/usage.db relative to project root)
DATABASE_URL=sqlite+aiosqlite:///data/usage.db

# Browser sessions directory (default: auth/sessions/)
SESSIONS_DIR=auth/sessions

# Scheduler refresh interval in minutes (default: 15)
REFRESH_INTERVAL_MINUTES=15

# Playwright browser (chromium, firefox, webkit — default: chromium)
PLAYWRIGHT_BROWSER=chromium

# Set to 1 to show browser window during collection (for debugging)
PLAYWRIGHT_HEADFUL=0
